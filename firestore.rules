rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasValidTimestamp() {
      return request.resource.data.keys().hasAny(['createdAt', 'updatedAt', 'timestamp']);
    }

    // User-specific data collections
    match /users/{userId} {
      // User can read/write their own user document
      allow read, write: if isOwner(userId);

      // Products collection
      match /products/{productId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
                      && request.resource.data.keys().hasAll(['id', 'name', 'category', 'currentStock', 'buyingPrice', 'sellingPrice'])
                      && request.resource.data.currentStock is int
                      && request.resource.data.buyingPrice is number
                      && request.resource.data.sellingPrice is number
                      && hasValidTimestamp();
        allow update: if isOwner(userId)
                      && request.resource.data.currentStock is int
                      && request.resource.data.buyingPrice is number
                      && request.resource.data.sellingPrice is number;
        allow delete: if isOwner(userId);
      }

      // Sales collection
      match /sales/{saleId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
                      && request.resource.data.keys().hasAll(['id', 'productId', 'quantity', 'unitPrice', 'totalAmount', 'saleType'])
                      && request.resource.data.quantity is int
                      && request.resource.data.quantity > 0
                      && request.resource.data.unitPrice is number
                      && request.resource.data.totalAmount is number
                      && request.resource.data.saleType in ['CASH', 'CREDIT']
                      && hasValidTimestamp();
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // Customers collection
      match /customers/{customerId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
                      && request.resource.data.keys().hasAll(['id', 'name', 'phone'])
                      && request.resource.data.name is string
                      && request.resource.data.phone is string
                      && hasValidTimestamp();
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // Credits collection
      match /credits/{creditId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
                      && request.resource.data.keys().hasAll(['id', 'customerId', 'totalAmount', 'amountPaid', 'remainingAmount', 'status'])
                      && request.resource.data.totalAmount is number
                      && request.resource.data.amountPaid is number
                      && request.resource.data.remainingAmount is number
                      && request.resource.data.status in ['UNPAID', 'PARTIAL', 'PAID']
                      && hasValidTimestamp();
        allow update: if isOwner(userId)
                      && request.resource.data.amountPaid >= resource.data.amountPaid // Prevent reducing paid amount
                      && request.resource.data.remainingAmount <= resource.data.remainingAmount; // Prevent increasing debt
        allow delete: if isOwner(userId);
      }

      // Payments collection
      match /payments/{paymentId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
                      && request.resource.data.keys().hasAll(['id', 'creditId', 'customerId', 'amount', 'paymentMethod'])
                      && request.resource.data.amount is number
                      && request.resource.data.amount > 0
                      && request.resource.data.paymentMethod in ['CASH', 'MOBILE_MONEY', 'BANK_TRANSFER']
                      && hasValidTimestamp();
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }

      // Inventory logs collection
      match /inventory_logs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
                      && request.resource.data.keys().hasAll(['id', 'productId', 'actionType', 'quantityChange', 'previousStock', 'newStock'])
                      && request.resource.data.quantityChange is int
                      && request.resource.data.previousStock is int
                      && request.resource.data.newStock is int
                      && request.resource.data.actionType in ['SALE', 'RESTOCK', 'ADJUST', 'SALE_REVERSAL']
                      && hasValidTimestamp();
        allow update: if false; // Inventory logs should be immutable
        allow delete: if isOwner(userId); // Allow deletion for cleanup
      }
    }

    // Deny access to any other documents
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
